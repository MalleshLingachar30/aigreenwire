{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "30 0 * * 1"
    },
    {
      "path": "/api/cron/resubscribe-reminders",
      "schedule": "0 1 * * 2"
    }
  ]
}
