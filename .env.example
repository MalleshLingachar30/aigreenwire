# Neon Postgres
# Pooled connection — use for all queries in API routes and Server Components
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Unpooled / direct connection — use ONLY for schema migrations (avoids PgBouncer issues)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=false

# Resend
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=The AI Green Wire <editor@aigreenwire.com>

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Admin / Cron security
CRON_SECRET=replace-with-a-random-32-char-string
ADMIN_SECRET=replace-with-a-random-32-char-string

# Editor preview destination
EDITOR_EMAIL=you@yourdomain.com

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://aigreenwire.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Approved Twilio Content Template SID for outbound media sends.
# Expected template shape:
# - static body text approved in Twilio/WhatsApp
# - media URL: https://your-domain{{1}}
TWILIO_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_STATUS_WEBHOOK_SECRET=replace-with-a-random-32-char-string

# WhatsApp distribution
WHATSAPP_AUTO_SEND_ENABLED=false
WHATSAPP_RECIPIENTS_JSON=[{"language":"kn","to":"whatsapp:+919999999999","label":"Kannada Test"}]
